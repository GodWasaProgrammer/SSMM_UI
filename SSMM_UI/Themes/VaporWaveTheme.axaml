<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Color x:Key="AccentColor">#F472B6</Color>
	<Color x:Key="AccentSecondaryColor">#A78BFA</Color>
	<Color x:Key="SurfaceColor">#1A0F2C</Color>
	<Color x:Key="CardColor">#27163D</Color>
	<Color x:Key="BorderColor">#5B3B8A</Color>
	<Color x:Key="MutedTextColor">#F5E8FF</Color>
	<Color x:Key="MenuColor">#201234</Color>
	<Color x:Key="MenuBorderColor">#6C4A98</Color>
	<Color x:Key="InputColor">#2A1A42</Color>
	<Color x:Key="InputBorderColor">#8B5CF6</Color>
	<Color x:Key="ShadowColor">#66000000</Color>

	<LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
		<GradientStop Color="#12091F" Offset="0" />
		<GradientStop Color="#23133B" Offset="0.55" />
		<GradientStop Color="#180C29" Offset="1" />
	</LinearGradientBrush>

	<LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
		<GradientStop Color="#A0F472B6" Offset="0" />
		<GradientStop Color="#90A78BFA" Offset="1" />
	</LinearGradientBrush>

	<SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
	<SolidColorBrush x:Key="AccentMutedBrush" Color="#C026D3" Opacity="0.65" />
	<SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource CardColor}" Opacity="0.9" />
	<SolidColorBrush x:Key="CardBorderBrush" Color="{DynamicResource BorderColor}" Opacity="0.75" />
	<SolidColorBrush x:Key="SurfaceOverlayBrush" Color="{DynamicResource SurfaceColor}" Opacity="0.92" />
	<SolidColorBrush x:Key="PanelOverlayBrush" Color="#311E4D" Opacity="0.75" />
	<SolidColorBrush x:Key="InputBackgroundBrush" Color="{DynamicResource InputColor}" Opacity="0.94" />
	<SolidColorBrush x:Key="InputBorderBrush" Color="{DynamicResource InputBorderColor}" Opacity="0.78" />
	<SolidColorBrush x:Key="TextSubtleBrush" Color="{DynamicResource MutedTextColor}" Opacity="0.83" />
	<SolidColorBrush x:Key="MenuBackgroundBrush" Color="{DynamicResource MenuColor}" Opacity="0.96" />
	<SolidColorBrush x:Key="MenuForegroundBrush" Color="#FDF4FF" />
	<SolidColorBrush x:Key="MenuBorderBrush" Color="{DynamicResource MenuBorderColor}" />
	<SolidColorBrush x:Key="GlassHighlightBrush" Color="#F5D0FE" Opacity="0.1" />
	<SolidColorBrush x:Key="AltHigh" Color="#FAF5FF" />

	<Color x:Key="SystemAccentColor">#F472B6</Color>
	<SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="{DynamicResource CardColor}" Opacity="0.94" />
	<SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush" Color="{DynamicResource BorderColor}" Opacity="0.72" />
	<SolidColorBrush x:Key="SystemControlForegroundAltHighBrush" Color="#FAF5FF" />
</ResourceDictionary>
