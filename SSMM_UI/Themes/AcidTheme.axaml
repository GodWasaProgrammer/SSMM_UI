<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Color x:Key="AccentColor">#A3FF12</Color>
	<Color x:Key="AccentSecondaryColor">#3BFFB6</Color>
	<Color x:Key="SurfaceColor">#08120A</Color>
	<Color x:Key="CardColor">#102015</Color>
	<Color x:Key="BorderColor">#2A5A2F</Color>
	<Color x:Key="MutedTextColor">#D9FFD9</Color>
	<Color x:Key="MenuColor">#0C180E</Color>
	<Color x:Key="MenuBorderColor">#3C7A3F</Color>
	<Color x:Key="InputColor">#112214</Color>
	<Color x:Key="InputBorderColor">#4A994E</Color>
	<Color x:Key="ShadowColor">#66000000</Color>

	<LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
		<GradientStop Color="#060F07" Offset="0" />
		<GradientStop Color="#122A16" Offset="0.55" />
		<GradientStop Color="#081108" Offset="1" />
	</LinearGradientBrush>

	<LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
		<GradientStop Color="#A0A3FF12" Offset="0" />
		<GradientStop Color="#903BFFB6" Offset="1" />
	</LinearGradientBrush>

	<SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
	<SolidColorBrush x:Key="AccentMutedBrush" Color="#65A30D" Opacity="0.72" />
	<SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource CardColor}" Opacity="0.9" />
	<SolidColorBrush x:Key="CardBorderBrush" Color="{DynamicResource BorderColor}" Opacity="0.75" />
	<SolidColorBrush x:Key="SurfaceOverlayBrush" Color="{DynamicResource SurfaceColor}" Opacity="0.92" />
	<SolidColorBrush x:Key="PanelOverlayBrush" Color="#17311C" Opacity="0.75" />
	<SolidColorBrush x:Key="InputBackgroundBrush" Color="{DynamicResource InputColor}" Opacity="0.94" />
	<SolidColorBrush x:Key="InputBorderBrush" Color="{DynamicResource InputBorderColor}" Opacity="0.78" />
	<SolidColorBrush x:Key="TextSubtleBrush" Color="{DynamicResource MutedTextColor}" Opacity="0.83" />
	<SolidColorBrush x:Key="MenuBackgroundBrush" Color="{DynamicResource MenuColor}" Opacity="0.96" />
	<SolidColorBrush x:Key="MenuForegroundBrush" Color="#E8FFE8" />
	<SolidColorBrush x:Key="MenuBorderBrush" Color="{DynamicResource MenuBorderColor}" />
	<SolidColorBrush x:Key="GlassHighlightBrush" Color="#BBF7D0" Opacity="0.1" />
	<SolidColorBrush x:Key="AltHigh" Color="#ECFDF5" />

	<Color x:Key="SystemAccentColor">#A3FF12</Color>
	<SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="{DynamicResource CardColor}" Opacity="0.94" />
	<SolidColorBrush x:Key="SystemControlBackgroundBaseLowBrush" Color="{DynamicResource BorderColor}" Opacity="0.72" />
	<SolidColorBrush x:Key="SystemControlForegroundAltHighBrush" Color="#F0FDF4" />
</ResourceDictionary>
