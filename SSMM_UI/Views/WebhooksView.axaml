<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="300"
			 xmlns:local="clr-namespace:SSMM_UI.ViewModel"
			 x:DataType="local:WebhooksViewModel"
             x:Class="SSMM_UI.Views.WebhooksView"
			 Title="Secrets And Keys For Social Poster">

	<ScrollViewer>
		<StackPanel Margin="20" Spacing="20">

			<StackPanel Orientation="Horizontal" Spacing="10">
				<Button Content="New Webhook" Command="{Binding AddWebhookCommand}"/>
				<Button Content="{Binding ToggleWebhooksButtonText}"
						Command="{Binding ToggleWebHooksCommand}"/>
			</StackPanel>

			<TextBlock Text="{Binding FeedbackMessage}"
					   Classes="secondary"
					   IsVisible="{Binding HasFeedbackMessage}"/>

			<Border Classes="card" IsVisible="{Binding IsAddingNewWebHook}">
				<StackPanel Spacing="8">
					<TextBox Watermark="Name of webhook" Text="{Binding NameofWebHook}"/>
					<TextBox  Watermark="Webhook link" Text="{Binding LinkOfWebhook}"/>
					<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
						<Button Content="Cancel" Classes="danger" Command="{Binding CancelNewWebHookCommand}"/>
						<Button Content="Add" Classes="success" Command="{Binding SaveNewWebHookCommand}"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<Border Classes="card">
				<StackPanel>
					<TextBlock Text="Webhooks" FontSize="16" FontWeight="Bold" Margin="0 0 0 10"/>

					<StackPanel Spacing="10">
						<ListBox ItemsSource="{Binding Webhooks}" Height="150" IsVisible="{Binding DisplayWebhooks}">
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="local:KeyValueItem">
									<StackPanel Spacing="8">
										<TextBlock Text="{Binding Key}" FontWeight="Bold"/>
										<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
											<TextBlock Grid.Column="0"
													   Text="{Binding DisplayValue}"
													   TextWrapping="Wrap"
													   VerticalAlignment="Center"/>
											<Button Grid.Column="1"
													Content="{Binding RevealButtonText}"
													Command="{ReflectionBinding DataContext.ToggleWebhookRevealCommand, RelativeSource={RelativeSource AncestorType=Window}}"
													CommandParameter="{Binding .}"
													Classes="primary"/>
											<Button Grid.Column="2"
													Content="Remove"
													Classes="danger"
													Command="{ReflectionBinding DataContext.RemoveWebhookCommand, RelativeSource={RelativeSource AncestorType=Window}}"
													CommandParameter="{Binding .}"/>
										</Grid>
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</StackPanel>

				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>
